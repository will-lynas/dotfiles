#!/usr/bin/env python3.11
from subprocess import check_output
from sys import argv

lines = [line.split("|") for line in check_output(
        'tmux list-panes -a -F '
        '"#{pane_id}|#{session_name}:#{window_index}.#{pane_index}|#{window_name}|#{pane_current_path}"',
        shell=True
        ).decode("utf-8").strip().split("\n")]
pane_id, name, window_name, path = [line for line in lines if line[1] == argv[1].split(" ")[0]][0]

number_of_commands = 10
try:
    with open(f"/tmp/tmux_pane_history/{pane_id}") as f:
        cmds = "\n".join([c for c in f.read().split("\n")[-(number_of_commands+1):] if c][::-1])
except FileNotFoundError:
    cmds = "<no command history>"

window_name = window_name or "<no window name>"

print(f"""
{name}
{window_name}

{path}

{cmds}
""".strip())
