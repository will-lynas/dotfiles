#!/usr/bin/env python3.11
from subprocess import check_output, CalledProcessError, DEVNULL
from collections import OrderedDict
import argparse

RED = '\033[31m'
GREEN = '\033[32m'
BLUE = '\033[34m'
ENDC = '\033[0m'

parser = argparse.ArgumentParser()
parser.add_argument("preview_line", nargs="?")
args = parser.parse_args()

def run_cmd(cmd, suppress=False):
    stderr = DEVNULL if suppress else None
    return check_output(cmd, shell=True, stderr=stderr).decode("utf-8")

def get_lines():
    out = [line.split("|") for line in run_cmd(
        'tmux list-panes -a -F '
        '"#{pane_id}|#{session_name}:#{window_index}.#{pane_index}|#{window_name}|#{pane_current_path}"'
        ).strip().split("\n")]
    for line in out:
        line[1] = line[1].replace(" ", "_")
    return out

def get_cmds(id, number_of_commands=10):
    try:
        with open(f"/tmp/tmux_pane_history/{id}") as f:
            return list(OrderedDict.fromkeys(
                        list(reversed(
                            list(filter(None, f.read().split("\n")))
                        ))
                    ))[:number_of_commands]
    except FileNotFoundError:
        return []

def get_git_root(path):
    try:
        path = run_cmd(f"git -C '{path}' rev-parse --show-toplevel", suppress=True).strip()
        return run_cmd(f"basename '{path}'").strip()
    except CalledProcessError:
        return path

if args.preview_line:
    name = args.preview_line.split(" ")[0]
    line = list(filter(lambda x: x[1] == name, get_lines()))[0]
    id, name, window_name, path = line
    root_path = get_git_root(path)
    window_name = window_name or "<no window name>"
    cmds = "\n".join(get_cmds(id)) or "<no command history>"
    print(f"""
{BLUE}{name}{ENDC} {GREEN}{window_name}{ENDC} {RED}{root_path}{ENDC}

{cmds}
    """.strip())
else:
    d = {}
    for line in get_lines():
        id = line[0]
        cmds = [cmd for cmd in get_cmds(id) if "'" not in cmd] # ' will break the echo command below
        remaining = list(filter(None, line[1:]))
        out_line = " ".join(remaining + cmds)
        d[out_line] = id
    joined_options = "\n".join(d.keys())
    try:
        line = run_cmd(
                f"echo '{joined_options}' | "
                "fzf --preview='~/dotfiles/bin/tmux_pane_finder {}' "
                "--preview-window=right,wrap --height='100%'"
                ).strip("\n")
        run_cmd(f"tmux switch-client -t '{d[line]}'")
    except CalledProcessError:
        pass
